PORT=5000
NODE_ENV=development

# Database
# Option A (recommended on Railway): use Railway-provided DATABASE_URL / MYSQL_* vars in Railway UI.
# If you want to use explicit DB_* vars instead, fill the values below.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sakupintar
DB_SSL=false

# JWT
JWT_SECRET=replace-me-with-a-long-random-string

# CORS (comma-separated). For dev you can leave empty.
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ORIGINS=
